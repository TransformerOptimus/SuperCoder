{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@superagi/meeting-desktop-repo": ["src/stubs/meetingSdk.ts"],
      "@superagi/meeting-desktop-repo/dist/ipc/protocol": ["src/stubs/meetingSdkProtocol.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__/**"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
