# Copy to .env and fill in. Used by docker-compose.yaml.

# Embedding API key (server-side, never injected by the desktop app).
# Required for indexing to produce embeddings.
SUPERCODER_OPENAI_API_KEY=sk-...

# Embedding model — 3072-dim. Default shown; rarely changed.
SUPERCODER_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
